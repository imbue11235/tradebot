# ─────────────────────────────────────────────────────────────
#  TRADEBOT — Environment Variables
#  Copy this file to .env and fill in your values.
#  The .env file is never committed or included in any zip.
# ─────────────────────────────────────────────────────────────

# ── Alpaca ────────────────────────────────────────────────────
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321

# ── Dashboard login (basic auth — your eyes only) ─────────────
DASHBOARD_USER=kaspar
DASHBOARD_PASSWORD=choose-a-strong-password-here

# ── Optional: Finnhub (free, real-time, 60 req/min) ──────────
# Get a free key at https://finnhub.io/register
# Supplements Alpaca news with additional real-time coverage.
# NewsAPI has been removed — free tier has 24h delay, useless for day trading.
FINNHUB_KEY=
